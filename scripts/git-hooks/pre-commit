#!/bin/sh
# Pre-commit hook: автоматическая валидация заданий ЕГЭ №9
# Устанавливается в .git/hooks/pre-commit

# Цвета для вывода (ANSI)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "${YELLOW}🔍 Запуск валидации заданий ЕГЭ №9...${NC}"

# Запускаем валидацию напрямую через node (надёжнее npm на Windows)
node scripts/validate-task9.cjs
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "${RED}❌ Валидация не пройдена!${NC}"
    echo "${RED}   Исправьте ошибки в заданиях перед коммитом.${NC}"
    echo ""
    exit 1
fi

echo ""
echo "${GREEN}✅ Валидация пройдена. Коммит разрешён.${NC}"
echo ""
exit 0
